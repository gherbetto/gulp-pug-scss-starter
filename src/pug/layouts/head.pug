    link(rel="icon" href="fav.svg" type="image/svg+xml")
    title #{title}
    script(src='js/libs/jquery.min.js' defer)
    script(src='js/libs/popper.min.js' defer)
    script(src='js/libs/bootstrap.min.js' defer)
    script(src='js/libs/slick.min.js' defer)
